# Сервер
PORT=3001
NODE_ENV=development

# База данных (MongoDB Atlas — бесплатно)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/autopostly

# JWT для авторизации пользователей
JWT_SECRET=your_super_secret_key_here_min_32_chars

# Telegram Bot
# Получить у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# VK
# Получить на vk.com/dev
VK_APP_ID=your_vk_app_id
VK_APP_SECRET=your_vk_app_secret

# Instagram / Meta
# Получить на developers.facebook.com
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# TikTok
# Получить на developers.tiktok.com
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# YouTube / Google
# Получить на console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Фронтенд (для CORS)
FRONTEND_URL=http://localhost:3000
